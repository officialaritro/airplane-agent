# =============================================================================
# Reroute - Flight Compensation Recovery Agent
# Environment Variables Configuration
# =============================================================================

# =============================================================================
# REQUIRED - Database
# =============================================================================

# PostgreSQL password (set this for both local and production)
PG_PASSWORD=your_secure_password_here

# =============================================================================
# REQUIRED - External APIs
# =============================================================================

# OpenSky Network (Flight Data) - Sign up at https://opensky-network.org/
# Go to Account > API Clients to create credentials
OPENSKY_CLIENT_ID=your_opensky_client_id
OPENSKY_CLIENT_SECRET=your_opensky_client_secret

# Resend (Email) - Sign up at https://resend.com
# Free tier: 3,000 emails/month
RESEND_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# OPTIONAL - E-Signature (DocuSeal)
# =============================================================================

# Auto-generated on first run, or generate with: openssl rand -base64 32
DOCUSEAL_SECRET=your_docuseal_secret_key

# =============================================================================
# OPTIONAL - Monitoring (Grafana)
# =============================================================================

GRAFANA_PASSWORD=admin

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Set to 'true' to see SQL queries in logs
SQL_ECHO=false
